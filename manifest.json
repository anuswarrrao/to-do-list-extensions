{
  "manifest_version": 3,
  "name": "To-Do List",
  "version": "1.0",
  "description": "A simple to-do list extension",
  "icons": {
    "48": "images/icon.png"
  },
  "permissions": [
    "storage"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open the To-Do List popup"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "images/icon.png",
    "default_popup": "popup/index.html"
  }
}